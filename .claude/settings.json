{
  "permissions": {
  "allow": [
      "Edit",
      "Bash(npm run *)",
      "Bash(git commit *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Read(./.env)"
    ],
    "ask": ["Bash(rm *)", "Bash(mv *)"],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp"
    ]
  }
}
